# POS Inventario - Git Ignore

# Sistema
Thumbs.db
*.log
php_error_log

# IDE
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# Config local
.env
.DS_Store

# Backup files
*.bak
*~

# Vendor y dependencias de terceros (se regeneran con composer / descarga directa)
extensiones/vendor/
extensiones/tcpdf/

# Dist y plugins de AdminLTE (se descargan de CDN o se incluyen al instalar)
vistas/dist/
vistas/plugins/

# Imagenes de productos y usuarios (contenido generado por el usuario)
vistas/img/productos/
vistas/img/usuarios/

# Artefactos de build (binarios > 100MB que GitHub rechaza)
dist/
